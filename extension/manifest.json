{
    "manifest_version": 3,
    "name": "SafeSphere Protection",
    "version": "1.0.0",
    "description": "Real-time scam, phishing and fraud protection.",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting",
        "notifications"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "SafeSphere Protection"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ]
}